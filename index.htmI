<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ETAG Smart Security Prototype</title>
    <!-- Links Telegram's SDK to remove borders and access native mobile features -->
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #1c1d1f;
            color: #ffffff;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .header {
            text-align: center;
            margin-bottom: 20px;
        }
        .card {
            background-color: #262729;
            border-radius: 16px;
            padding: 20px;
            width: 100%;
            max-width: 340px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.4);
            margin-bottom: 15px;
            box-sizing: border-box;
        }
        .status-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .status-badge {
            background-color: #06d6a0;
            color: #1c1d1f;
            padding: 6px 14px;
            border-radius: 20px;
            font-weight: bold;
            font-size: 14px;
        }
        .btn {
            background-color: #2481cc;
            color: white;
            border: none;
            padding: 14px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
            margin-top: 10px;
            transition: background 0.2s;
        }
        .btn:active {
            background-color: #1a639b;
        }
        .btn-danger {
            background-color: #ef476f;
        }
        .btn-danger:active {
            background-color: #c93b5c;
        }
    </style>
</head>
<body>

    <div class="header">
        <h2 style="margin-bottom: 5px;">ETAG Smart Security</h2>
        <p id="welcome" style="color: #aaaaaa; margin-top: 0; font-size: 14px;">Connecting to system...</p>
    </div>

    <!-- Live Status Monitoring -->
    <div class="card">
        <div class="status-container">
            <h3 style="margin: 0; font-size: 18px;">Door Locker</h3>
            <div class="status-badge" id="lock-status">LOCKED</div>
        </div>
    </div>

    <!-- Remote Controls -->
    <div class="card">
        <h3 style="margin-top: 0; margin-bottom: 15px; font-size: 16px; color: #aaaaaa;">Remote Actions</h3>
        <button class="btn" onclick="toggleLock()">Toggle Smart Lock</button>
        <button class="btn btn-danger" onclick="triggerAlarm()">Test Emergency Alarm</button>
    </div>

    <script>
        // Initialize the Telegram WebApp interface
        const tg = window.Telegram.WebApp;
        tg.expand(); // Expands the mini app sheet to maximize screen space

        // Personalize the dashboard using the customer's actual Telegram info
        const user = tg.initDataUnsafe?.user;
        if (user) {
            document.getElementById('welcome').innerText = `Active Session: ${user.first_name}`;
        } else {
            document.getElementById('welcome').innerText = `Active Session: Authorized Manager`;
        }

        function toggleLock() {
            const badge = document.getElementById('lock-status');
            if (badge.innerText === "LOCKED") {
                badge.innerText = "UNLOCKED";
                badge.style.backgroundColor = "#ef476f"; // Red warning color
            } else {
                badge.innerText = "LOCKED";
                badge.style.backgroundColor = "#06d6a0"; // Green secure color
            }
            // Triggers a premium haptic click sound/vibration on the user's mobile device
            if (tg.HapticFeedback) {
                tg.HapticFeedback.impactOccurred('medium');
            }
        }

        function triggerAlarm() {
            // Uses native Telegram popup windows for a seamless software feel
            tg.showAlert("🚨 Emergency Protocol: Mock alarm signal transmitted to ETAG node successfully.");
        }
    </script>
</body>
</html>
