<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ETAG Store</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body { font-family: sans-serif; background: var(--tg-theme-bg-color); color: var(--tg-theme-text-color); margin: 0; padding: 10px; }
        .product { border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; border-radius: 8px; }
        button { background: #2481cc; color: white; border: none; padding: 10px; width: 100%; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>
    <h1>ETAG Sneakers</h1>
    <div id="catalog">
        <div class="product">
            <h3>ETAG Runner Pro</h3>
            <p>$125.00</p>
            <button onclick="order('ETAG Runner Pro')">Buy Now</button>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp;
        tg.ready();

        function order(productName) {
            // This sends a message back to your bot chat
            tg.sendData(`Order: ${productName}`);
            tg.close();
        }
    </script>
</body>
</html>
